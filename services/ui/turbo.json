{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "globalDependencies": [],
  "cacheDir": ".turbo/cache",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "lib/**", "!node_modules/**"]
    },
    "bundle": {
      "dependsOn": ["build"]
    },
    "build:lib": {
      "outputs": ["lib/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "test": {
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    },
    "list": {
      "cache": false
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
