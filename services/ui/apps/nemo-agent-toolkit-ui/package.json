{
  "name": "nemo-agent-toolkit-ui",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp -r .next/static .next/standalone/apps/nemo-agent-toolkit-ui/.next/ && cp -r public .next/standalone/apps/nemo-agent-toolkit-ui/",
    "start": "node .next/standalone/apps/nemo-agent-toolkit-ui/server.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next && rm -rf node_modules",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@aiqtoolkit-ui/common": "*",
    "@nemo-agent-toolkit/ui": "0.1.1",
    "jsdom": "27.0.1",
    "next": "15.5.16",
    "next-i18next": "^13.2.2",
    "next-runtime-env": "^1.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "18.15.0",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "4.9.5"
  }
}
